generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Auth & Multi-tenancy ────────────────────────────────────────────────────

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  name          String?
  emailVerified Boolean      @default(false)
  passwordHash  String
  memberships  Membership[]
  posts        Post[]
  media        Media[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Tenant {
  id           String        @id @default(cuid())
  name         String
  slug         String        @unique
  customDomain String?       @unique
  themeKey     String        @default("starter")
  logo         String?
  description  String?       @db.Text
  onboardingCompleted Boolean @default(false)
  memberships  Membership[]
  pages        Page[]
  posts        Post[]
  categories   Category[]
  tags         Tag[]
  media        Media[]
  menuItems    MenuItem[]
  subscribers  Subscriber[]
  newsletters  Newsletter[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([slug])
}

enum Role {
  OWNER
  ADMIN
  EDITOR
}

model Membership {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId  String
  role      Role     @default(OWNER)
  createdAt DateTime @default(now())

  @@unique([userId, tenantId])
  @@index([tenantId])
}

// ─── Pages ───────────────────────────────────────────────────────────────────

model Page {
  id          String   @id @default(cuid())
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId    String
  slug        String
  title       String
  content     String   @db.LongText
  metaTitle   String?
  metaDesc    String?  @db.Text
  ogImage     String?
  published   Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, slug])
  @@index([tenantId, published])
}

// ─── Blog ────────────────────────────────────────────────────────────────────

model Post {
  id            String         @id @default(cuid())
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId      String
  author        User           @relation(fields: [authorId], references: [id])
  authorId      String
  slug          String
  title         String
  excerpt       String?        @db.Text
  content       String         @db.LongText
  featuredImage String?
  metaTitle     String?
  metaDesc      String?        @db.Text
  published     Boolean        @default(false)
  publishedAt   DateTime?
  categories    PostCategory[]
  tags          PostTag[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([tenantId, slug])
  @@index([tenantId, published, publishedAt])
}

model Category {
  id       String         @id @default(cuid())
  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId String
  name     String
  slug     String
  posts    PostCategory[]

  @@unique([tenantId, slug])
}

model Tag {
  id       String    @id @default(cuid())
  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId String
  name     String
  slug     String
  posts    PostTag[]

  @@unique([tenantId, slug])
}

model PostCategory {
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId     String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId String

  @@id([postId, categoryId])
}

model PostTag {
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId String
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId  String

  @@id([postId, tagId])
}

// ─── Media ───────────────────────────────────────────────────────────────────

model Media {
  id           String   @id @default(cuid())
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId     String
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])
  uploadedById String
  filename     String
  originalName String
  mimeType     String
  size         Int
  url          String
  alt          String?
  width        Int?
  height       Int?
  createdAt    DateTime @default(now())

  @@index([tenantId, createdAt])
}

// ─── Navigation ──────────────────────────────────────────────────────────────

model MenuItem {
  id       String     @id @default(cuid())
  tenant   Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId String
  label    String
  url      String
  position Int        @default(0)
  parent   MenuItem?  @relation("MenuChildren", fields: [parentId], references: [id], onDelete: Cascade)
  parentId String?
  children MenuItem[] @relation("MenuChildren")

  @@index([tenantId, position])
}

// ─── Newsletter ──────────────────────────────────────────────────────────────

model Subscriber {
  id           String   @id @default(cuid())
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId     String
  email        String
  name         String?
  status       String   @default("active")
  subscribedAt DateTime @default(now())

  @@unique([tenantId, email])
  @@index([tenantId, status])
}

model Newsletter {
  id        String    @id @default(cuid())
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId  String
  subject   String
  content   String    @db.LongText
  status    String    @default("draft")
  sentAt    DateTime?
  sentCount Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([tenantId, status])
}

// ─── Auth Tokens ─────────────────────────────────────────────────────────────

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

// ─── Analytics ──────────────────────────────────────────────────────────────

model PageView {
  id        String   @id @default(cuid())
  tenantId  String
  path      String
  referrer  String?
  userAgent String?  @db.Text
  country   String?
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, path])
}
